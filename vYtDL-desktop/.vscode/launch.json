{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Next.js: debug server-side",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/apps/desktop",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Tauri: debug Rust backend",
      "cargo": {
        "args": [
          "build",
          "--manifest-path",
          "${workspaceFolder}/apps/desktop/src-tauri/Cargo.toml",
          "--no-default-features"
        ]
      },
      "preLaunchTask": "ui:build"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Next.js: debug client-side",
      "port": 9231,
      "cwd": "${workspaceFolder}/apps/desktop",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/apps/desktop/**",
        "!**/node_modules/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Full stack: Next.js + Tauri",
      "configurations": ["Next.js: debug server-side", "Next.js: debug client-side"],
      "stopAll": true
    }
  ]
}
