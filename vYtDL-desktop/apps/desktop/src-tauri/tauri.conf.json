{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "vYtDL Desktop",
  "version": "0.1.0",
  "identifier": "com.vytdl.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3002",
    "beforeDevCommand": "node ./node_modules/next/dist/bin/next dev --port 3002",
    "beforeBuildCommand": "node ./node_modules/next/dist/bin/next build"
  },
  "app": {
    "windows": [
      {
        "title": "vYtDL Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/yt-dlp": "yt-dlp"
    }
  }
}
