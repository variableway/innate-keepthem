{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/player/layout,_N_T_/player/[id]/layout,_N_T_/player/[id]/page,_N_T_/player/placeholder"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/player/$d$id/__PAGE__",
    "/player/$d$id",
    "/player",
    "/_index",
    "/_head"
  ]
}