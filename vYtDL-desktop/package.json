{
  "name": "vytdl-desktop-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @vytdl/desktop dev",
    "build": "pnpm --filter @vytdl/desktop build",
    "tauri": "pnpm --filter @vytdl/desktop tauri",
    "tauri:dev": "pnpm --filter @vytdl/desktop tauri:dev",
    "tauri:build": "pnpm --filter @vytdl/desktop tauri:build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
